# CanveraOS — Dolphin File Manager Configuration
# macOS Finder-style sidebar: Home, Desktop, Documents, Downloads, Music, Pictures, Videos, Trash
# No system disk entries, no terminal panel at bottom.
# Place at: ~/.config/dolphinrc

[General]
BrowseThroughArchives=false
ConfirmClosingMultipleTabs=true
EditableUrl=false
HomeUrl=file:///home
OpenNewTabAfterLastTab=true
RememberOpenedTabs=true
ShowFullPath=false
ShowFullPathInTitlebar=false
ShowStatusBar=true
ShowToolbar=true
ShowZoomSlider=true
SortingChoice=SortByName
UseTabForSwitchingSplitView=false
Version=202
ViewPropsTimestamp=2024,1,1,0,0,0

[DetailsMode]
DateWidth=120
GroupWidth=100
NameWidth=260
PermissionsWidth=0
RatingWidth=0
SizeWidth=80
TagsWidth=0
TypeWidth=120

[IconsMode]
IconSize=48
PreviewSize=96

[KFileDialog Settings]
Allow Expansion=false
Automatically select filename extension=true

[MainWindow]
MenuBar=Disabled
ToolBarsMovable=Disabled

[PreviewSettings]
Plugins=appimagethumbnail,audiothumbnail,blenderthumbnail,comicbookthumbnail,cursorthumbnail,djvuthumbnail,ebookthumbnail,exrthumbnail,directorythumbnail,fontthumbnail,imagethumbnail,jpegthumbnail,kraorathumbnail,windowsexethumbnail,windowsimagethumbnail,mobithumbnail,opendocumentthumbnail,pdf,ffmpegthumbs,svgthumbnail,textthumbnail,krita,xcfthumbnail

[PlacesPanel]
IconSize=22
TagsVisible=false
# Hide system storage devices (hard disks, root filesystem) — macOS Finder style
# 0 = visible, 1 = hidden
# Groups: Places=0, Remote=2, Devices/Storage=3, Tags=4
HiddenSections=storage devices

[Search]
Location=Everywhere
SearchFor=FileAndFolders

[SettingsDialog]
Width=640
Height=480

[ViewModes]
# Icon view (0) — like macOS Finder default
ViewMode=0

[Sidebar]
Visible=true
Width=220

# ── Terminal panel ─────────────────────────────────────────────────────────────
# Visible=false = terminal panel at the bottom is CLOSED by default
# User can still open it with F4
[Terminal]
Visible=false
Height=150

[ContentDisplay]
IconSize=22
